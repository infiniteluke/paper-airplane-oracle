# Anthropic API key — https://platform.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Password gating /admin (the query log viewer). Pick anything.
ADMIN_PASSWORD=lakeside

# Upstash Redis (optional in local dev — falls back to .oracle-log.json).
# In production (Vercel), add the Upstash Redis integration and these are set automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
